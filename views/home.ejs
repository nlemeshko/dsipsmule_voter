<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Голосование - dsipsmule.one | NASSAL2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/">Голосование</a>
          <a href="/polls/<%= poll.slug %>/report">Отчет</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">Мини-сервис голосования</span>
          <h1><%= poll.title %></h1>
          <p>
            <%= poll.description || "Выберите сильнейшего участника в этом этапе." %>
          </p>

          <% if (telegramStatus) { %>
            <div class="notice"><%= telegramStatus %></div>
          <% } %>

          <% if (currentUser) { %>
            <div class="user-chip">
              <% if (currentUser.photo_url) { %>
                <img src="<%= currentUser.photo_url %>" alt="<%= currentUser.full_name %>" />
              <% } %>
              <div>
                <strong><%= currentUser.full_name %></strong>
                <span><%= currentUser.username ? `@${currentUser.username}` : "без username" %></span>
              </div>
            </div>
            <form method="post" action="/auth/logout">
              <button class="ghost-button" type="submit">Выйти</button>
            </form>
          <% } else { %>
            <% if (telegramConfigured) { %>
              <div class="widget-wrap">
                <script
                  async
                  src="https://telegram.org/js/telegram-widget.js?23"
                  data-telegram-login="<%= telegramBotUsername %>"
                  data-size="large"
                  data-userpic="false"
                  data-auth-url="<%= telegramAuthUrl %>"
                ></script>
              </div>
            <% } else { %>
              <div class="notice">
                Telegram вход пока не настроен. Заполните `.env` и свяжите домен
                через `/setdomain` в BotFather.
              </div>
            <% } %>
          <% } %>
        </div>

        <% if (currentUser && votingProgress && votingProgress.status === "active") { %>
          <div class="notice">
            Раунд <%= votingProgress.roundNumber %>. Выберите
            <%= votingProgress.stageType === "triple" ? "одного из трех" : "одного из двух" %>.
          </div>
          <% if (votingProgress.canUndo) { %>
            <form method="post" action="/vote/back">
              <input type="hidden" name="poll_id" value="<%= poll.id %>" />
              <input type="hidden" name="poll_slug" value="<%= poll.slug %>" />
              <button class="ghost-button" type="submit">Назад к предыдущему выбору</button>
            </form>
          <% } %>
          <section class="duel <%= votingProgress.stageType === 'triple' ? 'duel-triple' : '' %>">
            <% votingProgress.participants.forEach((participant, index) => { %>
              <article class="contestant">
                <div class="contestant-media">
                  <% if (participant.audio_url) { %>
                    <div class="audio-entry">
                      <span class="audio-entry-label">Запись <%= index + 1 %></span>
                      <audio class="audio-player" controls preload="none" data-listen-url="/polls/<%= poll.slug %>/participants/<%= participant.id %>/listen">
                        <source src="<%= participant.audio_url %>" type="audio/mp4" />
                        Ваш браузер не поддерживает встроенный аудиоплеер.
                      </audio>
                    </div>
                  <% } else { %>
                    <div class="notice">M4A для этой записи еще не загружен.</div>
                  <% } %>
                </div>
                <div class="contestant-copy">
                  <h2>Анонимная запись <%= index + 1 %></h2>
                </div>
                <form method="post" action="/vote">
                  <input type="hidden" name="poll_id" value="<%= poll.id %>" />
                  <input type="hidden" name="poll_slug" value="<%= poll.slug %>" />
                  <input type="hidden" name="winner_id" value="<%= participant.id %>" />
                  <button class="vote-button" type="submit">Голосовать</button>
                </form>
              </article>
              <% if (votingProgress.stageType !== "triple" && index === 0) { %>
                <div class="versus">VS</div>
              <% } %>
            <% }) %>
          </section>
        <% } else if (currentUser && votingProgress && votingProgress.status === "completed") { %>
          <div class="notice">
            Вы уже завершили голосование.
          </div>
          <a class="primary-button" href="/polls/<%= poll.slug %>/thanks">Продолжить</a>
        <% } else if (currentUser) { %>
          <div class="notice">
            Для старта добавьте минимум двух активных участников через админку.
          </div>
        <% } %>
      </section>
      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
    <script src="/site.js"></script>
  </body>
</html>
