<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Голосование - dsipsmule.one | NASSAL2026</title>
    <% if (typeof redirectUrl !== "undefined" && typeof redirectDelay !== "undefined" && redirectUrl && redirectDelay) { %>
      <meta http-equiv="refresh" content="<%= redirectDelay %>;url=<%= redirectUrl %>" />
    <% } %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell shell-narrow">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/">Голосование</a>
          <a href="javascript:history.back()">Назад</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="panel">
        <span class="eyebrow">Ошибка</span>
        <h1><%= title %></h1>
        <p><%= message %></p>
        <% if (typeof redirectUrl !== "undefined" && typeof redirectDelay !== "undefined" && redirectUrl && redirectDelay) { %>
          <p>Через <%= redirectDelay %> секунд вы будете перенаправлены на главную.</p>
        <% } %>
        <a class="primary-button" href="/">На главную</a>
      </section>
      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
  </body>
</html>
