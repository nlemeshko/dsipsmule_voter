<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Админка голосования</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell dashboard-shell">
      <section class="dashboard-topbar">
        <div>
          <span class="eyebrow">Панель управления</span>
          <h1>Статистика голосования</h1>
        </div>
        <form method="post" action="/admin/logout">
          <button class="ghost-button" type="submit">Выйти</button>
        </form>
      </section>

      <section class="stat-grid">
        <article class="stat-card">
          <span>Голосования</span>
          <strong><%= totals.polls %></strong>
        </article>
        <article class="stat-card">
          <span>Пользователи Telegram</span>
          <strong><%= totals.users %></strong>
        </article>
        <article class="stat-card">
          <span>Всего голосов</span>
          <strong><%= totals.votes %></strong>
        </article>
        <article class="stat-card">
          <span>Прослушивания</span>
          <strong><%= totals.listens %></strong>
        </article>
        <article class="stat-card">
          <span>Активные участники</span>
          <strong><%= totals.participants %></strong>
        </article>
      </section>

      <section class="admin-grid">
        <article class="panel">
          <h2>Создать голосование</h2>
          <form class="stack-form" method="post" action="/admin/polls" enctype="multipart/form-data">
            <label>
              <span>Название</span>
              <input type="text" name="title" required />
            </label>
            <label>
              <span>Slug</span>
              <input type="text" name="slug" placeholder="stage-1" />
            </label>
            <label>
              <span>Описание</span>
              <textarea name="description" rows="3"></textarea>
            </label>
            <label>
              <span>Картинка этапа по ссылке</span>
              <input type="url" name="image_url" placeholder="https://..." />
            </label>
            <label>
              <span>Или загрузите картинку</span>
              <input type="file" name="image_file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*" />
            </label>
            <label>
              <span>Ссылка редиректа после завершения</span>
              <input type="url" name="redirect_url" value="https://dsipsmule.one" />
            </label>
            <button class="primary-button" type="submit">Создать этап</button>
          </form>
        </article>

        <article class="panel">
          <h2>Лидеры</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Участник</th>
                  <th>Побед</th>
                </tr>
              </thead>
              <tbody>
                <% leaderboard.forEach((row) => { %>
                  <tr>
                    <td><%= row.name %></td>
                    <td><%= row.wins %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </article>

        <article class="panel">
          <h2>Добавить участника</h2>
          <% if (registrationsError) { %>
            <div class="notice notice-error"><%= registrationsError %></div>
          <% } %>
          <form class="stack-form" method="post" action="/admin/participants">
            <label>
              <span>Голосование</span>
              <select name="poll_id" required>
                <option value="">Выберите этап</option>
                <% polls.forEach((poll) => { %>
                  <option value="<%= poll.id %>"><%= poll.title %> (/polls/<%= poll.slug %>)</option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Участник из регистраций</span>
              <select name="registration_key" required>
                <option value="">Выберите участника</option>
                <% registrations.forEach((registration) => { %>
                  <option value="<%= registration.key %>">
                    <%= registration.participants %> · <%= registration.category_name %><%= registration.telegram_username ? ` · @${registration.telegram_username}` : "" %>
                  </option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Прямая аудиоссылка</span>
              <textarea name="embed_html" rows="4" placeholder="https://.../track.m4a или https://.../track.mp3" required></textarea>
            </label>
            <label>
              <span>Название песни</span>
              <input type="text" name="song_title" placeholder="Введите название песни" />
            </label>
            <div class="participant-source-actions">
              <button class="primary-button" type="submit">Сохранить источник</button>
            </div>
          </form>
        </article>
      </section>

      <section class="panel">
        <h2>Ссылки на голосования</h2>
        <div class="cards-grid">
          <% polls.forEach((poll) => { %>
            <article class="mini-card">
              <% if (poll.image_url) { %>
                <img class="mini-card-cover" src="<%= poll.image_url %>" alt="<%= poll.title %>" />
              <% } %>
              <div>
                <strong><%= poll.title %></strong>
                <p><%= poll.description || "Без описания" %></p>
                <span><%= baseUrl %>/polls/<%= poll.slug %></span>
                <span><%= poll.is_visible ? "Видимость: Видно на главной" : "Видимость: Скрыт с главной" %></span>
                <span>Статус: <%= poll.is_active ? "Открыт" : "Закрыт" %></span>
              </div>
              <form class="stack-form" method="post" action="/admin/polls/<%= poll.id %>/update" enctype="multipart/form-data">
                <label>
                  <span>Картинка по ссылке</span>
                  <input type="url" name="image_url" value="<%= poll.image_url || "" %>" placeholder="https://..." />
                </label>
                <label>
                  <span>Или новая загрузка</span>
                  <input type="file" name="image_file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*" />
                </label>
                <button class="ghost-button" type="submit">Сохранить картинку</button>
              </form>
              <form method="post" action="/admin/polls/<%= poll.id %>/visibility">
                <button class="ghost-button" type="submit">
                  <%= poll.is_visible ? "Скрыть этап" : "Показать этап" %>
                </button>
              </form>
              <form method="post" action="/admin/polls/<%= poll.id %>/toggle">
                <button class="ghost-button" type="submit">
                  <%= poll.is_active ? "Закрыть этап" : "Открыть этап" %>
                </button>
              </form>
              <a class="ghost-button" href="/polls/<%= poll.slug %>/report">
                <%= poll.is_active ? "Превью отчета" : "Открыть отчет" %>
              </a>
              <form method="post" action="/admin/polls/<%= poll.id %>/delete">
                <button class="ghost-button danger-button" type="submit">Удалить этап</button>
              </form>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="panel">
        <h2>Участники</h2>
        <div class="poll-groups">
          <% pollsWithParticipants.forEach((poll, index) => { %>
            <details class="poll-group" <%= index === 0 ? "open" : "" %>>
              <summary class="poll-group-summary">
                <div>
                  <strong><%= poll.title %></strong>
                  <span><%= baseUrl %>/polls/<%= poll.slug %></span>
                </div>
                <div class="poll-group-meta">
                  <span>Участников: <%= poll.participantCount %></span>
                  <span>Голосов: <%= poll.voteCount %></span>
                  <span>Прослушиваний: <%= poll.listenCount %></span>
                  <span>Людей: <%= poll.uniqueVoterCount %></span>
                </div>
              </summary>

              <% if (poll.participants.length === 0) { %>
                <div class="notice">В этом этапе пока нет участников.</div>
              <% } else { %>
                <div class="table-wrap">
                  <table>
                    <thead>
                      <tr>
                        <th>Имя</th>
                        <th>Статус</th>
                        <th>Аудио</th>
                        <th>Статистика</th>
                        <th>Редактирование</th>
                        <th>Действия</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% poll.participants.forEach((participant) => { %>
                        <tr>
                          <td class="participant-name-cell">
                            <div class="participant-identity">
                              <% if (participant.image_url) { %>
                                <img class="participant-avatar" src="<%= participant.image_url %>" alt="<%= participant.name %>" />
                              <% } else { %>
                                <span class="participant-avatar participant-avatar-fallback"><%= (participant.name || "?").trim().charAt(0).toUpperCase() %></span>
                              <% } %>
                              <div class="participant-copy">
                                <strong><%= participant.name %></strong>
                                <% if (participant.description) { %>
                                  <span class="participant-song-title"><%= participant.description %></span>
                                <% } %>
                              </div>
                            </div>
                            <% if (participant.witcher_choice) { %>
                              <span class="admin-witcher-choice">Выбор Ведьмака</span>
                            <% } %>
                          </td>
                          <td><%= participant.is_active ? "Активен" : "Отключен" %></td>
                          <td class="payload-cell">
                            <% if (participant.playback_url) { %>
                              <div class="audio-entry">
                                <span class="audio-entry-label">Внешний аудиоисточник</span>
                                <audio
                                  class="audio-player"
                                  controls
                                  preload="none"
                                  controlsList="nodownload noplaybackrate"
                                  src="<%= participant.playback_url %>"
                                ></audio>
                              </div>
                            <% } else { %>
                              <div class="notice">Аудиоссылка еще не добавлена.</div>
                            <% } %>
                          </td>
                          <td class="participant-stats-cell">
                            <details class="participant-votes">
                              <summary>
                                <strong><%= participant.voteCount %></strong>
                                <span>голосов</span>
                              </summary>
                              <% if (participant.voteDetails.length === 0) { %>
                                <div class="notice">За этого участника еще не голосовали.</div>
                              <% } else { %>
                                <div class="table-wrap">
                                  <table>
                                    <thead>
                                      <tr>
                                        <th>Когда</th>
                                        <th>Telegram ID</th>
                                        <th>Имя</th>
                                        <th>Username</th>
                                        <th>Против кого</th>
                                      </tr>
                                    </thead>
                                    <tbody>
                                      <% participant.voteDetails.forEach((vote) => { %>
                                        <tr>
                                          <td><%= formatDate(vote.created_at) %></td>
                                          <td><%= vote.telegram_id %></td>
                                          <td><%= vote.full_name || "—" %></td>
                                          <td><%= vote.username ? `@${vote.username}` : "—" %></td>
                                          <td><%= vote.loser_name || "—" %></td>
                                        </tr>
                                      <% }) %>
                                    </tbody>
                                  </table>
                                </div>
                              <% } %>
                            </details>
                            <details class="participant-votes">
                              <summary>
                                <strong><%= participant.listenCount %></strong>
                                <span>прослушиваний</span>
                              </summary>
                              <% if (participant.listenDetails.length === 0) { %>
                                <div class="notice">Эту запись еще не запускали.</div>
                              <% } else { %>
                                <div class="notice">
                                  Уникальных слушателей: <strong><%= participant.uniqueListenerCount %></strong>
                                </div>
                                <div class="table-wrap">
                                  <table>
                                    <thead>
                                      <tr>
                                        <th>Когда</th>
                                        <th>Telegram ID</th>
                                        <th>Имя</th>
                                        <th>Username</th>
                                      </tr>
                                    </thead>
                                    <tbody>
                                      <% participant.listenDetails.forEach((listen) => { %>
                                        <tr>
                                          <td><%= formatDate(listen.created_at) %></td>
                                          <td><%= listen.telegram_id %></td>
                                          <td><%= listen.full_name || "—" %></td>
                                          <td><%= listen.username ? `@${listen.username}` : "—" %></td>
                                        </tr>
                                      <% }) %>
                                    </tbody>
                                  </table>
                                </div>
                              <% } %>
                            </details>
                          </td>
                          <td class="participant-edit-cell">
                            <form class="stack-form participant-edit-form" method="post" action="/admin/participants/<%= participant.id %>/update">
                              <label>
                                <span>Участник из регистраций</span>
                                <select name="registration_key" required>
                                  <option value="">Выберите участника</option>
                                  <% if (!participantRegistrationKeys[participant.id]) { %>
                                    <option value="" selected><%= participant.name %> · текущий участник не найден в CSV</option>
                                  <% } %>
                                  <% registrations.forEach((registration) => { %>
                                    <option value="<%= registration.key %>" <%= participantRegistrationKeys[participant.id] === registration.key ? "selected" : "" %>>
                                      <%= registration.participants %> · <%= registration.category_name %><%= registration.telegram_username ? ` · @${registration.telegram_username}` : "" %>
                                    </option>
                                  <% }) %>
                                </select>
                              </label>
                              <label>
                                <span>Новая прямая аудиоссылка</span>
                                <textarea name="embed_html" rows="4" placeholder="https://.../track.m4a или https://.../track.mp3"><%= participant.audio_source_url || "" %></textarea>
                              </label>
                              <label>
                                <span>Название песни</span>
                                <input type="text" name="song_title" value="<%= participant.description || "" %>" placeholder="Введите название песни" />
                              </label>
                              <div class="participant-source-actions">
                                <button class="primary-button" type="submit">Сохранить изменения</button>
                              </div>
                            </form>
                          </td>
                          <td class="participant-actions">
                            <form method="post" action="/admin/participants/<%= participant.id %>/witcher-toggle">
                              <button class="ghost-button <%= participant.witcher_choice ? '' : 'witcher-button' %>" type="submit">
                                <%= participant.witcher_choice ? "Снять выбор Ведьмака" : "Выбор Ведьмака" %>
                              </button>
                            </form>
                            <form method="post" action="/admin/participants/<%= participant.id %>/toggle">
                              <button class="ghost-button" type="submit">
                                <%= participant.is_active ? "Отключить" : "Включить" %>
                              </button>
                            </form>
                            <form method="post" action="/admin/participants/<%= participant.id %>/delete">
                              <button class="ghost-button danger-button" type="submit">Удалить</button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </details>
          <% }) %>
        </div>
      </section>

      <section class="panel">
        <h2>Кто вошел через Telegram</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Telegram ID</th>
                <th>Имя</th>
                <th>Username</th>
                <th>Raw Telegram payload</th>
                <th>Первый вход</th>
                <th>Последний вход</th>
                <th>Входов</th>
                <th>Сброс голосов</th>
              </tr>
            </thead>
            <tbody>
              <% recentUsers.forEach((user) => { %>
                <tr>
                  <td><%= user.telegram_id %></td>
                  <td><%= user.full_name || "—" %></td>
                  <td><%= user.username ? `@${user.username}` : "—" %></td>
                  <td class="payload-cell">
                    <details>
                      <summary>Показать</summary>
                      <pre><%= user.raw_profile_json || "{}" %></pre>
                    </details>
                  </td>
                  <td><%= formatDate(user.first_login_at) %></td>
                  <td><%= formatDate(user.last_login_at) %></td>
                  <td><%= user.login_count %></td>
                  <td>
                    <form method="post" action="/admin/users/<%= user.id %>/reset-votes">
                      <button class="ghost-button danger-button" type="submit">Сбросить голоса</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="panel">
        <h2>Последние голоса</h2>
        <div class="stack-list">
          <% recentVotes.forEach((userVotes) => { %>
            <details class="participant-votes vote-user-group">
              <summary>
                <strong><%= userVotes.full_name || "—" %></strong>
                <span>
                  <%= userVotes.username ? `@${userVotes.username}` : "без username" %>
                  · Telegram ID: <%= userVotes.telegram_id %>
                </span>
                <span>
                  Последний голос: <%= formatDate(userVotes.last_vote_at) %>
                  · Всего голосов: <%= userVotes.votes.length %>
                </span>
              </summary>
              <div class="vote-user-summary-actions">
                <form method="post" action="/admin/users/<%= userVotes.user_id %>/reset-votes">
                  <button class="ghost-button danger-button" type="submit">Сбросить голоса пользователя</button>
                </form>
              </div>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Когда</th>
                      <th>Выбрал</th>
                      <th>Против</th>
                      <th>Этап</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% userVotes.votes.forEach((vote) => { %>
                      <tr>
                        <td><%= formatDate(vote.created_at) %></td>
                        <td><%= vote.winner_name %></td>
                        <td><%= vote.loser_name %></td>
                        <td><%= vote.poll_title %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </details>
          <% }) %>
        </div>
      </section>
      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
  </body>
</html>
