<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Голосование - dsipsmule.one | NASSAL2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell dashboard-shell">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/">Голосование</a>
          <a href="/polls/<%= poll.slug %>/report">Отчет</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">Отчет</span>
          <h1><%= poll.title %></h1>
          <p><%= poll.description || "Подробная статистика завершенного голосования." %></p>
          <div class="poll-group-meta">
            <span class="<%= poll.is_active ? 'status-open' : 'status-closed' %>">Статус: <%= poll.is_active ? "Открыт" : "Закрыт" %></span>
            <span>Участников: <%= report.totals.participants %></span>
            <span>Голосов: <%= report.totals.votes %></span>
            <span>Людей: <%= report.totals.voters %></span>
          </div>
        </div>
      </section>

      <section class="panel">
        <h2>Итоги по участникам</h2>
        <div class="poll-groups">
          <%
            let currentPlace = 0;
            let lastVoteCount = null;
          %>
          <% report.participants.forEach((participant, index) => { %>
            <%
              if (lastVoteCount === null || participant.voteCount !== lastVoteCount) {
                currentPlace = index + 1;
                lastVoteCount = participant.voteCount;
              }
            %>
            <details class="poll-group">
              <summary class="poll-group-summary">
                <div class="report-participant-heading">
                  <span class="report-place-badge report-place-<%= Math.min(currentPlace, 3) %>">#<%= currentPlace %></span>
                </div>
                <div class="report-participant-copy">
                  <strong class="report-participant-title">
                    <span><%= participant.name %></span>
                    <% if (participant.witcher_choice) { %>
                      <img class="report-witcher-badge" src="/witcher-choice.png" alt="Выбор Ведьмака" />
                    <% } %>
                  </strong>
                  <span class="report-participant-meta">
                    <span class="report-votes-metric"><span class="report-votes-label">Голосов:</span> <%= participant.voteCount %></span>
                    <% if (participant.witcher_choice) { %>
                      <span class="report-bonus-note">(+2 выбор Ведьмака)</span>
                    <% } %>
                    <span class="report-people-metric">| Людей: <%= participant.uniqueVoterCount %></span>
                  </span>
                </div>
              </summary>
              <div class="report-participant-body">
                <div class="report-participant-layout">
                  <% if (participant.embed_html) { %>
                    <aside class="report-participant-media">
                      <div class="mini-embed mini-embed-compact"><%- participant.embed_html %></div>
                    </aside>
                  <% } %>

                  <div class="report-participant-stats">
                    <% if (participant.voteDetails.length === 0) { %>
                      <div class="notice">За этого участника не было голосов.</div>
                    <% } else { %>
                      <div class="table-wrap">
                        <table class="report-table">
                          <thead>
                            <tr>
                              <th>Когда</th>
                              <th>Telegram ID</th>
                              <th>Пользователь</th>
                              <th>Username</th>
                              <th>Против кого</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% participant.voteDetails.forEach((vote) => { %>
                              <tr>
                                <td data-label="Когда"><%= formatDate(vote.created_at) %></td>
                                <td data-label="Telegram ID"><%= vote.telegram_id %></td>
                                <td data-label="Пользователь">
                                  <div class="report-user">
                                    <% if (vote.photo_url) { %>
                                      <img class="report-user-avatar" src="<%= vote.photo_url %>" alt="<%= vote.full_name || vote.telegram_id %>" />
                                    <% } else { %>
                                      <span class="report-user-avatar report-user-fallback"><%= (vote.full_name || vote.telegram_id || "?").trim().charAt(0).toUpperCase() %></span>
                                    <% } %>
                                    <span><%= vote.full_name || "—" %></span>
                                  </div>
                                </td>
                                <td data-label="Username"><%= vote.username ? `@${vote.username}` : "—" %></td>
                                <td data-label="Против кого"><%= vote.loser_name || "—" %></td>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>
            </details>
          <% }) %>
        </div>
      </section>

      <% 
        const chartColors = ["#8fa8c1", "#c5d3e1", "#6e86a0", "#d9c39a", "#8bb6a6", "#b991c8", "#86a9b6", "#d28787"];
        const chartParticipants = report.participants.filter((participant) => participant.voteCount > 0);
        const chartRadius = 42;
        const chartCircumference = 2 * Math.PI * chartRadius;
        let chartOffset = 0;
        const chartSlices = chartParticipants.map((participant, index) => {
          const percent = report.totals.votes ? (participant.voteCount / report.totals.votes) * 100 : 0;
          const dash = (percent / 100) * chartCircumference;
          const offset = chartOffset;
          chartOffset += dash;
          return {
            ...participant,
            color: chartColors[index % chartColors.length],
            percent,
            dash,
            offset,
          };
        });
      %>
      <section class="panel">
        <h2>Распределение голосов</h2>
        <div class="report-chart-layout">
          <div class="report-chart-card">
            <div class="report-chart">
              <svg class="report-chart-svg" viewBox="0 0 100 100" aria-label="Распределение голосов">
                <circle class="report-chart-track" cx="50" cy="50" r="42"></circle>
                <% chartSlices.forEach((slice) => { %>
                  <circle
                    class="report-chart-segment"
                    cx="50"
                    cy="50"
                    r="42"
                    stroke="<%= slice.color %>"
                    stroke-dasharray="<%= slice.dash %> <%= chartCircumference - slice.dash %>"
                    stroke-dashoffset="<%= -slice.offset %>"
                    tabindex="0"
                    data-tooltip="<%= `${slice.name} — ${slice.voteCount} голосов (${slice.percent.toFixed(1)}%)` %>"
                  >
                  </circle>
                <% }) %>
              </svg>
              <div class="report-chart-tooltip" id="report-chart-tooltip" aria-hidden="true"></div>
              <div class="report-chart-center">
                <strong><%= report.totals.votes %></strong>
                <span>голосов</span>
              </div>
            </div>
          </div>
          <div class="report-chart-legend">
            <% if (chartSlices.length === 0) { %>
              <div class="notice">По этому этапу пока нет голосов.</div>
            <% } else { %>
              <% chartSlices.forEach((slice) => { %>
                <div class="report-chart-item">
                  <span class="report-chart-swatch" style="background: <%= slice.color %>;"></span>
                  <div class="report-chart-copy">
                    <strong><%= slice.name %></strong>
                    <span><%= slice.voteCount %> голосов</span>
                  </div>
                  <strong class="report-chart-percent"><%= slice.percent.toFixed(1) %>%</strong>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </section>

      <section class="panel report-export-panel">
        <h2>Выгрузка</h2>
        <p>Скачать Excel-файл со всей статистикой этапа, участниками и полным логом голосов.</p>
        <a class="primary-button" href="/polls/<%= poll.slug %>/report/export.xls">Скачать Excel</a>
      </section>

      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
    <script src="/report-chart.js"></script>
  </body>
</html>
