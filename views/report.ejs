<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>dsipsmule.one - NASSAL2026 - Голосование</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="preloading">
    <div class="page-preloader" id="page-preloader" aria-hidden="true">
      <img
        class="page-preloader-image"
        src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image.png"
        alt="Loading"
      />
    </div>
    <main class="shell dashboard-shell">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/polls/<%= poll.slug %>">Голосование</a>
          <a href="/polls/<%= poll.slug %>/report">Отчет</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">Отчет</span>
          <h1><%= poll.title %></h1>
          <p><%= poll.description || "Подробная статистика завершенного голосования." %></p>
          <div class="poll-group-meta">
            <span>Статус: <%= poll.is_active ? "Открыт" : "Закрыт" %></span>
            <span>Участников: <%= report.totals.participants %></span>
            <span>Голосов: <%= report.totals.votes %></span>
            <span>Людей: <%= report.totals.voters %></span>
          </div>
        </div>
      </section>

      <section class="panel">
        <h2>Итоги по участникам</h2>
        <div class="poll-groups">
          <% report.participants.forEach((participant, index) => { %>
            <details class="poll-group" <%= index === 0 ? "open" : "" %>>
              <summary class="poll-group-summary">
                <div>
                  <strong><%= participant.name %></strong>
                  <span>Голосов: <%= participant.voteCount %> | Людей: <%= participant.uniqueVoterCount %></span>
                </div>
              </summary>
              <div class="report-participant-body">
                <% if (participant.embed_html) { %>
                  <div class="mini-embed"><%- participant.embed_html %></div>
                <% } %>

                <% if (participant.voteDetails.length === 0) { %>
                  <div class="notice">За этого участника не было голосов.</div>
                <% } else { %>
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>Когда</th>
                          <th>Telegram ID</th>
                          <th>Пользователь</th>
                          <th>Username</th>
                          <th>Против кого</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% participant.voteDetails.forEach((vote) => { %>
                          <tr>
                            <td><%= formatDate(vote.created_at) %></td>
                            <td><%= vote.telegram_id %></td>
                            <td>
                              <div class="report-user">
                                <% if (vote.photo_url) { %>
                                  <img class="report-user-avatar" src="<%= vote.photo_url %>" alt="<%= vote.full_name || vote.telegram_id %>" />
                                <% } else { %>
                                  <span class="report-user-avatar report-user-fallback"><%= (vote.full_name || vote.telegram_id || "?").trim().charAt(0).toUpperCase() %></span>
                                <% } %>
                                <span><%= vote.full_name || "—" %></span>
                              </div>
                            </td>
                            <td><%= vote.username ? `@${vote.username}` : "—" %></td>
                            <td><%= vote.loser_name || "—" %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } %>
              </div>
            </details>
          <% }) %>
        </div>
      </section>

      <section class="panel">
        <h2>Последние голоса этапа</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Когда</th>
                <th>Telegram ID</th>
                <th>Пользователь</th>
                <th>Username</th>
                <th>Против кого</th>
              </tr>
            </thead>
            <tbody>
              <% report.recentVotes.forEach((vote) => { %>
                <tr>
                  <td><%= formatDate(vote.created_at) %></td>
                  <td><%= vote.telegram_id %></td>
                  <td>
                    <div class="report-user">
                      <% if (vote.photo_url) { %>
                        <img class="report-user-avatar" src="<%= vote.photo_url %>" alt="<%= vote.full_name || vote.telegram_id %>" />
                      <% } else { %>
                        <span class="report-user-avatar report-user-fallback"><%= (vote.full_name || vote.telegram_id || "?").trim().charAt(0).toUpperCase() %></span>
                      <% } %>
                      <span><%= vote.full_name || "—" %></span>
                    </div>
                  </td>
                  <td><%= vote.username ? `@${vote.username}` : "—" %></td>
                  <td><%= vote.loser_name || "—" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
    <script src="/site.js"></script>
  </body>
</html>
