<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Голосование - dsipsmule.one | NASSAL2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/">Голосование</a>
          <a href="https://dsipsmule.one/nassal-2026/" target="_blank" rel="noreferrer">NASSAL2026</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">Голосования</span>
          <h1>Выберите этап.</h1>
          <p>У каждого этапа свои участники, своя ссылка и отдельное прохождение.</p>
          <% if (!currentUser && telegramConfigured) { %>
            <div class="widget-wrap">
              <script
                async
                src="https://telegram.org/js/telegram-widget.js?23"
                data-telegram-login="<%= telegramBotUsername %>"
                data-size="large"
                data-userpic="false"
                data-auth-url="<%= telegramAuthUrl %>"
              ></script>
            </div>
          <% } %>
        </div>

        <section class="cards-grid">
          <% polls.forEach((poll) => { %>
            <article class="mini-card">
              <% if (poll.image_url) { %>
                <img class="mini-card-cover" src="<%= poll.image_url %>" alt="<%= poll.title %>" />
              <% } %>
              <div>
                <strong><%= poll.title %></strong>
                <p><%= poll.description || "Описание пока не добавлено." %></p>
                <% if (!poll.is_visible) { %>
                  <span>Скрыт с главной</span>
                <% } %>
                <span class="<%= poll.is_active ? 'status-open' : 'status-closed' %>"><%= poll.is_active ? "Статус: Открыт" : "Статус: Закрыт" %></span>
              </div>
              <% if (poll.is_active) { %>
                <a class="primary-button" href="/polls/<%= poll.slug %>">Открыть этап</a>
              <% } else { %>
                <a class="ghost-button" href="/polls/<%= poll.slug %>/report">Открыть отчет</a>
              <% } %>
            </article>
          <% }) %>
        </section>
      </section>
      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
  </body>
</html>
