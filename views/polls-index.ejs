<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Голосование - dsipsmule.one | NASSAL2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <header class="site-brand">
        <nav class="site-brand-nav" aria-label="Основная навигация">
          <a href="https://dsipsmule.one" target="_blank" rel="noreferrer">Главная</a>
          <a href="/">Голосование</a>
          <a href="https://dsipsmule.one/nassal-2026/" target="_blank" rel="noreferrer">NASSAL2026</a>
        </nav>
        <img
          class="site-brand-logo"
          src="https://dsipsmule.one/wp-content/uploads/2025/09/cropped-image-1.png"
          alt="dsipsmule.one"
        />
        <div class="site-brand-copy">
          <span class="site-brand-domain">dsipsmule.one</span>
          <strong>NASSAL2026</strong>
          <span>Голосование</span>
        </div>
      </header>
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">Голосования</span>
          <h1>Выберите этап.</h1>
          <p>У каждого этапа свои участники, своя ссылка и отдельное прохождение.</p>
          <% if (!currentUser && telegramConfigured) { %>
            <div class="widget-wrap">
              <script
                async
                src="https://telegram.org/js/telegram-widget.js?23"
                data-telegram-login="<%= telegramBotUsername %>"
                data-size="large"
                data-userpic="false"
                data-auth-url="<%= telegramAuthUrl %>"
              ></script>
            </div>
          <% } %>
        </div>

        <section class="cards-grid">
          <% polls.forEach((poll) => { %>
            <article class="mini-card">
              <% if (poll.image_url) { %>
                <img class="mini-card-cover mini-card-cover-top" src="<%= poll.image_url %>" alt="<%= poll.title %>" />
              <% } %>
              <div>
                <strong><%= poll.title %></strong>
                <p><%= poll.description || "Описание пока не добавлено." %></p>
                <% if (!poll.is_visible) { %>
                  <span>Скрыт с главной</span>
                <% } %>
                <span class="<%= poll.is_active ? 'status-open' : 'status-closed' %>"><%= poll.is_active ? "Статус: Открыт" : "Статус: Закрыт" %></span>
              </div>
              <% if (poll.is_active) { %>
                <a class="primary-button" href="/polls/<%= poll.slug %>">Открыть этап</a>
              <% } else { %>
                <a class="ghost-button" href="/polls/<%= poll.slug %>/report">Открыть отчет</a>
              <% } %>
            </article>
          <% }) %>
        </section>

        <% if (globalBettingStage && globalBettingStage.availableBasketCount > 0) { %>
          <section class="betting-launchpad">
            <details
              class="betting-panel"
              id="bet-panel-burmalda"
              <%= expandedBetSlug === "burmalda" ? "open" : "" %>
            >
              <summary class="ghost-button betting-toggle">Бурмалда</summary>
              <% if (!bettingCatalogAvailable || !globalBettingStage) { %>
                <div class="betting-panel-body">
                  <div class="notice">Ставки временно недоступны: не удалось загрузить корзины участников.</div>
                </div>
              <% } else { %>
                <div class="betting-panel-body">
                  <div class="betting-art">
                    <img
                      class="betting-art-image"
                      src="/burmalda.png"
                      alt="Бурмалда"
                    />
                  </div>
                  <div class="betting-panel-copy">
                    <p>
                      Это общее голосование по всем регистрациям. Выберите по одному победителю в каждой корзине, и после ставки увидите текущие проценты.
                    </p>
                    <% if (currentUser) { %>
                      <span class="betting-progress">
                        Корзин закрыто: <%= globalBettingStage.completedBasketCount %> из <%= globalBettingStage.availableBasketCount %>
                      </span>
                    <% } else { %>
                      <span class="betting-progress">Для ставки войдите через Telegram.</span>
                    <% } %>
                  </div>

                  <div class="betting-baskets-grid">
                    <% globalBettingStage.baskets.forEach((basket) => { %>
                      <details class="betting-basket" <%= basket.hasUserBet ? "open" : "" %>>
                        <summary class="betting-basket-head">
                          <span class="betting-basket-kicker">Корзина <%= basket.code %></span>
                          <h3><%= basket.shortName %></h3>
                          <p><%= basket.fullName %></p>
                          <% if (basket.totalBets > 0) { %>
                            <span class="betting-basket-total">Всего ставок: <%= basket.totalBets %></span>
                          <% } %>
                        </summary>

                        <% if (basket.participants.length === 0) { %>
                          <div class="betting-empty">В этой корзине пока нет участников для этого этапа.</div>
                        <% } else { %>
                          <div class="betting-table-wrap">
                            <table class="betting-table">
                              <thead>
                                <tr>
                                  <th>Участник</th>
                                  <th>Ставка</th>
                                  <th>Процент</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% basket.participants.forEach((participant) => { %>
                                  <tr class="<%= participant.isSelected ? 'is-picked' : '' %>">
                                    <td>
                                      <div class="betting-participant">
                                        <% if (participant.image_url) { %>
                                          <img src="<%= participant.image_url %>" alt="<%= participant.name %>" />
                                        <% } %>
                                        <div>
                                          <strong><%= participant.name %></strong>
                                          <% if (participant.description) { %>
                                            <span><%= participant.description %></span>
                                          <% } %>
                                        </div>
                                      </div>
                                    </td>
                                    <td>
                                      <% if (currentUser) { %>
                                        <form method="post" action="/bets">
                                          <input type="hidden" name="basket_code" value="<%= basket.code %>" />
                                          <input type="hidden" name="participant_id" value="<%= participant.id %>" />
                                          <button class="<%= participant.isSelected ? 'primary-button' : 'ghost-button' %> betting-action" type="submit">
                                            <%= participant.isSelected ? "Ваша ставка" : "Поставить" %>
                                          </button>
                                        </form>
                                      <% } else { %>
                                        <span class="betting-lock">Нужен вход</span>
                                      <% } %>
                                    </td>
                                    <td>
                                      <% if (basket.hasUserBet) { %>
                                        <div class="betting-percent-cell">
                                          <strong><%= participant.percentLabel %></strong>
                                          <span><%= participant.betCount %> ставок</span>
                                        </div>
                                      <% } else { %>
                                        <span class="betting-hidden-percent">Появится после вашей ставки</span>
                                      <% } %>
                                    </td>
                                  </tr>
                                <% }) %>
                              </tbody>
                            </table>
                          </div>
                        <% } %>
                      </details>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            </details>
          </section>
        <% } %>
      </section>
      <footer class="site-footer">
        <span>© 2026 Witcher by <a href="https://mdsn.work" target="_blank" rel="noreferrer">MDSN</a> | All Rights Reserved | Powered by <a href="https://t.me/kelahselai" target="_blank" rel="noreferrer">Nicky</a></span>
      </footer>
    </main>
    <script src="/site.js"></script>
  </body>
</html>
